# ── Servidor ──────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Anthropic (Claude) ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-tu-clave-aqui
CLAUDE_MODEL=claude-sonnet-5
CLAUDE_MAX_TOKENS=1024

# ── PostgreSQL ────────────────────────────────────────────────────────────
# Dentro de docker-compose el host es "postgres" (nombre del servicio).
POSTGRES_DB=recepcionista_db
POSTGRES_USER=recepcionista_user
POSTGRES_PASSWORD=cambiar-esta-clave
DATABASE_URL=postgresql://recepcionista_user:cambiar-esta-clave@postgres:5432/recepcionista_db

# ── Evolution API (WhatsApp) ─────────────────────────────────────────────
# URL base de tu instancia de Evolution API y su api key global/instancia.
EVOLUTION_API_URL=https://tu-evolution-api.com
EVOLUTION_API_KEY=tu-api-key
EVOLUTION_INSTANCE=nombre-de-tu-instancia

# Token propio para validar que el webhook viene de tu Evolution API
# (lo agregás como query param ?token=... al configurar el webhook en Evolution).
WEBHOOK_VERIFY_TOKEN=un-token-secreto-inventado-por-vos

# ── Negocio (fallback si no editás src/utils/businessConfig.js) ──────────
RECEPTIONIST_PHONE=5492235551234
